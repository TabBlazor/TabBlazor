@page "/docs/forms/typeaheads"

<Page>
    <DocsExample Title="Typeahead" ComponentType="typeof(Typeahead<,>)">

        <CodeSnippet Component="@typeof(TypeaheadsBasic)" Title="Basic"/>
        <CodeSnippet Component="@typeof(TypeaheadsShowOptions)" Title="ShowOptions"/>
        <CodeSnippet Component="@typeof(TypeaheadsConvertExpression)" Title="Convert Expression"/>
        <CodeSnippet Component="@typeof(TypeaheadsFlush)" Title="Flush"/>

        <CodeSnippet Component="@typeof(TypeaheadsInTable)" Title="Inside a table">
            <Description>
                Use <code>Positioning="Positioning.Fixed"</code> when the typeahead sits
                inside a scroll container or table cell. The result list is positioned
                in the viewport so it isn't clipped by overflow. Requires
                <code>options.EnablePopper = true</code> in <code>AddTabBlazor</code>.
            </Description>
        </CodeSnippet>

    </DocsExample>
</Page>
