@using Microsoft.Extensions.DependencyInjection
@using TabBlazor.Components.Tables

@code {
    private static void Configure(IServiceCollection services)
    {
        services.AddTabBlazor(options =>
        {
            options.DefaultPositioning = Positioning.Fixed;
            options.EnablePopper = true;
            options.PopperScriptUrl = "https://unpkg.com/@popperjs/core@2";
            options.DefaultOnCancelStrategy = OnCancelStrategy.AsIs;
            options.AssemblyScanFilter = () => AppDomain.CurrentDomain.GetAssemblies().ToList();
        });
    }
}
